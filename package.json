{
    "name": "obsidian-pdf-scholia-scribe",
    "version": "0.40.49",
    "description": "Citation-focused PDF annotation and note-linking.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MichelleGDyason/pdf-scholia-scribe.git"
    },
    "bugs": {
        "url": "https://github.com/MichelleGDyason/pdf-scholia-scribe/issues"
    },
    "homepage": "https://github.com/MichelleGDyason/pdf-scholia-scribe#readme",
    "funding": "https://github.com/sponsors/MichelleGDyason",
    "dependencies": {
        "@codemirror/view": "6.38.6"
    },
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "lint": "eslint src/ --ext .ts,.tsx",
        "lint:obsidian": "eslint .",
        "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
        "review": "pnpm build && pnpm lint:obsidian",
        "version": "node version-bump.mjs && git add manifest.json versions.json"
    },
    "keywords": [],
    "author": "Michelle G Dyason",
    "license": "MIT",
    "devDependencies": {
        "@cantoo/pdf-lib": "^2.4.3",
        "@capacitor/app": "^7.0.2",
        "@capacitor/core": "^7.4.3",
        "@capacitor/device": "^7.0.2",
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.34.0",
        "@types/node": "^24.3.0",
        "@typescript-eslint/eslint-plugin": "8.x",
        "@typescript-eslint/parser": "8.x",
        "electron": "^37.4.0",
        "esbuild": "0.25.9",
        "eslint": "^9.34.0",
        "eslint-plugin-obsidianmd": "^0.4.1",
        "globals": "^16.3.0",
        "monkey-around": "^3.0.0",
        "obsidian": "latest",
        "p-limit": "^7.1.1",
        "pdfjs-dist": "^5.4.54",
        "tslib": "2.8.1",
        "typescript": "5.x"
    },
    "packageManager": "pnpm@11.8.0"
}
